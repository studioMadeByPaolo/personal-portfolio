# Railway injects DATABASE_URL automatically when you attach a Postgres plugin.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Local dev only — Railway sets PORT automatically.
PORT=3000

# OPTIONAL: email notifications via Resend (https://resend.com).
# If both vars are set, every form submission also pings your inbox.
# Leave empty to skip — messages are still saved to the DB.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
NOTIFY_EMAIL=studio@madebypaolo.it
